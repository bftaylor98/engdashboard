{
  "name": "engineering-schedule-dashboard",
  "version": "4.3.0",
  "description": "Local-first Engineering Schedule Dashboard",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"wait-on http://localhost:3001/api/health -t 60000 && npm run client:dev\"",
    "client:dev": "vite",
    "server:dev": "node --watch server/index.js",
